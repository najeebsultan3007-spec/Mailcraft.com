# MailCraft AI Backend — Environment Variables
# Copy to .env and fill in your values

# Your Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Admin panel password (change this!)
ADMIN_PASSWORD=mailcraft2024

# Server port (Railway sets this automatically)
PORT=3001

# Allowed frontend origins (* = allow all, good for testing)
# Production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# Optional: override model
# MODEL=claude-sonnet-4-20250514

# Optional: override max tokens
# MAX_TOKENS=1000
