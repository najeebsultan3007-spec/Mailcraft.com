"builds": [
  { "src": "server.js", "use": "@vercel/node" },
  { "src": "*.html", "use": "@vercel/static" }       ← ✅ saari HTML files static
],
"routes": [
  { "src": "/api/(.*)", "dest": "server.js" },
  { "src": "/health", "dest": "server.js" },
  { "src": "/admin.html", "dest": "/admin.html" },   ← ✅ admin.html static serve
  { "src": "/privacy.html", "dest": "/privacy.html" },
  { "src": "/terms.html", "dest": "/terms.html" },
  { "src": "/contact.html", "dest": "/contact.html" },
  { "src": "/(.*)", "dest": "/index.html" }
]
